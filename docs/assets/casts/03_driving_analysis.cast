[0.5, "o", "\u001b[1;36m=== 03: Driving Analysis (CoT) ===\u001b[0m\r\n"]
[1.0, "o", "Loading nvidia/Cosmos-Reason2-2B (vision, reasoning=True)..."]
[2.5, "o", " ✅ loaded\r\n"]
[3.0, "o", "Processing video: sample.mp4 @ 4 FPS... 40 frames\r\n"]
[3.5, "o", "\r\n\u001b[1;33mAgent:\u001b[0m "]
[4.0, "o", "\u001b[2;33m<think>\u001b[0m\r\n"]
[4.3, "o", "\u001b[2;33mLet me analyze this dashcam footage step by step.\u001b[0m\r\n\r\n"]
[4.8, "o", "\u001b[2;33mFirst, I'll identify the key elements in the scene:\u001b[0m\r\n"]
[5.2, "o", "\u001b[2;33m- This is a suburban residential street\u001b[0m\r\n"]
[5.5, "o", "\u001b[2;33m- Multiple parked vehicles on both sides\u001b[0m\r\n"]
[5.8, "o", "\u001b[2;33m- A pedestrian on the right sidewalk\u001b[0m\r\n"]
[6.1, "o", "\u001b[2;33m- Trees creating partial shade\u001b[0m\r\n"]
[6.4, "o", "\u001b[2;33m- Road appears dry, good visibility\u001b[0m\r\n\r\n"]
[6.9, "o", "\u001b[2;33mNow, potential hazards:\u001b[0m\r\n"]
[7.2, "o", "\u001b[2;33m1. The pedestrian could step into the road\u001b[0m\r\n"]
[7.5, "o", "\u001b[2;33m2. A car could open a door from parked vehicles\u001b[0m\r\n"]
[7.8, "o", "\u001b[2;33m3. Limited visibility at upcoming intersection\u001b[0m\r\n"]
[8.1, "o", "\u001b[2;33m4. Children might be playing behind parked cars\u001b[0m\r\n\r\n"]
[8.5, "o", "\u001b[2;33mRecommended actions:\u001b[0m\r\n"]
[8.8, "o", "\u001b[2;33m- Maintain speed at or below 25 mph\u001b[0m\r\n"]
[9.1, "o", "\u001b[2;33m- Give wide berth to parked cars (door zone)\u001b[0m\r\n"]
[9.4, "o", "\u001b[2;33m- Monitor pedestrian trajectory\u001b[0m\r\n"]
[9.7, "o", "\u001b[2;33m- Prepare to brake at intersection\u001b[0m\r\n"]
[10.0, "o", "\u001b[2;33m</think>\u001b[0m\r\n\r\n"]
[10.5, "o", "\u001b[1m⚠️  Safety Hazards Identified:\u001b[0m\r\n"]
[10.8, "o", "• Pedestrian on right sidewalk — risk of jaywalking\r\n"]
[11.1, "o", "• Parked cars on both sides — door opening risk\r\n"]
[11.4, "o", "• Upcoming intersection — limited cross-traffic visibility\r\n\r\n"]
[11.8, "o", "\u001b[1m✅ Recommended Actions:\u001b[0m\r\n"]
[12.1, "o", "• Maintain ≤25 mph through residential zone\r\n"]
[12.4, "o", "• Stay center-lane, avoid door zone\r\n"]
[12.7, "o", "• Watch for pedestrian course changes\r\n"]
[13.0, "o", "• Slow to 15 mph approaching intersection\r\n"]
[13.5, "o", "\r\n\u001b[1;32mTime: 16.4s\u001b[0m\r\n"]
[14.0, "o", "\u001b[1;32m=== PASS ===\u001b[0m\r\n"]
